			inst.TextSize = math.clamp((inst.TextSize > 0 and inst.TextSize or 12) + math.random(-2, 1), 8, 16)
			inst.TextColor3 = Color3.fromRGB(math.random(205, 255), math.random(28, 95), math.random(28, 95))
			inst.TextStrokeColor3 = Color3.fromRGB(math.random(10, 55), 0, 0)
			inst.TextStrokeTransparency = math.random(12, 42) / 100
			inst.TextTransparency = math.random(0, 12) / 100

			if inst:IsA("TextBox") then
				inst.PlaceholderText = meta.text
			end
		end)
		meta.setting = false
	end

	local function trackText(inst)
		if uiMutationStopped then
			return
		end

		if not shouldTrackText(inst) then
			return
		end

		if trackedTexts[inst] then
			if not trackedTexts[inst].listed then
				trackedTexts[inst].listed = true
				trackedList[#trackedList + 1] = inst
			end
			forceText(inst, false)
			return
		end

		local meta = {
			index = getStableIndex(inst),
			text = "",
			isSelfName = isSelfNameText(inst.Text) or isSelfNameText(inst.Name) or isLikelySelfNameObject(inst),
			setting = false,
			listed = true,
			connections = {},
		}
		trackedTexts[inst] = meta
		trackedList[#trackedList + 1] = inst

		meta.connections[#meta.connections + 1] = inst:GetPropertyChangedSignal("Text"):Connect(function()
			local current = trackedTexts[inst]
			if current and not current.setting then
				if isSelfNameText(inst.Text) then
					current.isSelfName = true
				end
				forceText(inst, true)
			end
		end)

		meta.connections[#meta.connections + 1] = inst.AncestryChanged:Connect(function(_, parent)
			if not parent then
				local current = trackedTexts[inst]
				if current then
					for _, conn in ipairs(current.connections) do
						conn:Disconnect()
					end
					trackedTexts[inst] = nil
				end
			end
		end)

		forceText(inst, false)
	end

	local function enqueue(inst)
		if uiMutationStopped then
			return
		end

		if not inst then
			return
		end

		if isWhitelistedUi(inst) then
			return
		end

		if scanQueued[inst] or scannedInstances[inst] then
			return
		end

		scanningDone = false
		scanQueued[inst] = true
		scanQueue[#scanQueue + 1] = inst
	end

	local function enqueueDescendants(root)
		enqueue(root)
	end

	local function rescanRootTexts(root, maxItems)
		if not root then
			return
		end

		if isWhitelistedUi(root) then
			return
		end

		local ok, descendants = pcall(function()
			return root:GetDescendants()
		end)

		if not ok then
			return
		end

		local tracked = 0
		local limit = maxItems or 240
		for i = 1, #descendants do
			local inst = descendants[i]
			if shouldTrackText(inst) then
				scannedInstances[inst] = nil
				trackText(inst)
				tracked += 1
				if tracked >= limit then
					return
				end
			end

			if i % 100 == 0 then
				task.wait()
			end
		end
	end

	local function enqueuePriorityOfficialUi()
		local ok, descendants = pcall(function()
			return CoreGui:GetDescendants()
		end)

		if not ok then
			return
		end

		for i = 1, #descendants do
			local inst = descendants[i]
			local name = string.lower(inst.Name)
			if shouldTrackText(inst) then
				trackText(inst)
				enqueue(inst)
			elseif string.find(name, "player")
				or string.find(name, "leader")
				or string.find(name, "topbar")
				or string.find(name, "chrome")
				or string.find(name, "menu")
				or string.find(name, "experience")
				or string.find(name, "inspect") then
				enqueue(inst)
			end

			if i % 80 == 0 then
				task.wait()
			end
		end
	end

	local function pulsePlayerList()
		pcall(function()
			StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.PlayerList, true)
		end)

		task.defer(enqueuePriorityOfficialUi)
	end

	local function compactScanQueue()
		if scanHead > 64 and scanHead > #scanQueue / 2 then
			for i = scanHead, #scanQueue do
				scanQueue[i - scanHead + 1] = scanQueue[i]
			end

			for i = #scanQueue - scanHead + 2, #scanQueue do
				scanQueue[i] = nil
			end

			scanHead = 1
		end
	end

	local function scanStep(maxItems, budgetSeconds)
		local processed = 0
		local deadline = os.clock() + budgetSeconds

		while processed < maxItems and scanHead <= #scanQueue and os.clock() < deadline do
			local inst = scanQueue[scanHead]
			scanQueue[scanHead] = nil
			scanHead += 1
			if inst then
				scanQueued[inst] = nil
			end

			if inst and isWhitelistedUi(inst) then
				scannedInstances[inst] = true
			elseif inst and not scannedInstances[inst] and (watchedRoots[inst] or inst.Parent) then
				scannedInstances[inst] = true

				if shouldTrackText(inst) then
					trackText(inst)
				end

				local ok, children = pcall(function()
					return inst:GetChildren()
				end)

				if ok then
					for i = 1, #children do
						enqueue(children[i])
					end
				end
			end

			processed += 1
		end

		if scanHead > #scanQueue then
			scanHead = 1
			table.clear(scanQueue)
			scanningDone = true
			return
		end

		compactScanQueue()
	end

	local function animateTrackedTexts(advance, maxItems)
		if uiMutationStopped then
			return
		end

		local total = #trackedList
		if total == 0 then
			return
		end

		local processed = 0
		while processed < maxItems and total > 0 do
			if animateIndex > #trackedList then
				animateIndex = 1
			end

			local inst = trackedList[animateIndex]
			local meta = inst and trackedTexts[inst]

			if not inst or not inst.Parent or not meta or isWhitelistedUi(inst) then
				if meta then
					for _, conn in ipairs(meta.connections) do
						conn:Disconnect()
					end
					trackedTexts[inst] = nil
				end
				table.remove(trackedList, animateIndex)
				total = #trackedList
			else
				forceText(inst, advance)
				animateIndex += 1
			end

			processed += 1
		end
	end

	local function animateMovesTexts(maxItems)
		if uiMutationStopped then
			return
		end

		local total = #trackedList
		if total == 0 then
			return
		end

		local processed = 0
		local checked = 0
		while processed < maxItems and checked < total do
			if movesAnimateIndex > #trackedList then
				movesAnimateIndex = 1
			end

			local inst = trackedList[movesAnimateIndex]
			local meta = inst and trackedTexts[inst]
			if inst and inst.Parent and meta and not isWhitelistedUi(inst) and isInsideMovesRoot(inst) then
				forceText(inst, true)
				processed += 1
			end

			movesAnimateIndex += 1
			checked += 1
		end
	end

	local function animateTrackedFonts(maxItems, budgetSeconds)
		local total = #trackedList
		if total == 0 then
			return
		end

		local processed = 0
		local deadline = os.clock() + (budgetSeconds or 0.004)
		while processed < maxItems and total > 0 and os.clock() < deadline do
			if fontAnimateIndex > #trackedList then
				fontAnimateIndex = 1
			end

			local inst = trackedList[fontAnimateIndex]
			local meta = inst and trackedTexts[inst]
			if inst and inst.Parent and meta and not isWhitelistedUi(inst) then
				pcall(applyGlitchFont, inst)
			end

			fontAnimateIndex += 1
			processed += 1
		end
	end

	local function cleanupTrackedTexts()
		for inst, meta in pairs(trackedTexts) do
			if not inst or not inst.Parent or isWhitelistedUi(inst) then
				for _, conn in ipairs(meta.connections) do
					conn:Disconnect()
				end
				trackedTexts[inst] = nil
			end
		end
	end

	local function refreshSelfNameTexts()
		if uiMutationStopped then
			return
		end

		for inst, meta in pairs(trackedTexts) do
			if inst and inst.Parent and meta.isSelfName then
				forceText(inst, false)
			end
		end
	end

	local function refreshUntrackedRoots(maxQueued)
		scanningDone = false
		local queued = 0
		local limit = maxQueued or 100

		for root in pairs(watchedRoots) do
			if root and root.Parent and not isWhitelistedUi(root) then
				local ok, descendants = pcall(function()
					return root:GetDescendants()
				end)

				if ok then
					for i = 1, #descendants do
						local inst = descendants[i]
						if shouldTrackText(inst) and not trackedTexts[inst] then
							scannedInstances[inst] = nil
							enqueue(inst)
							queued += 1
							if queued >= limit then
								return
							end
						end

						if i % 120 == 0 then
							task.wait()
						end
					end
				end
			end
		end
	end

	local function watchRoot(root, label)
		if not root or watchedRoots[root] or isWhitelistedUi(root) then
			return
		end

		watchedRoots[root] = true
		if label and string.find(label, "Gameplay.Moves", 1, true) then
			movesRoots[root] = true
			task.defer(rescanRootTexts, root, 260)
		end
		enqueue(root)

		local ok, err = pcall(function()
			root.DescendantAdded:Connect(function(inst)
				if isWhitelistedUi(inst) then
					return
				end

				if shouldTrackText(inst) then
					trackText(inst)
				end

				task.defer(enqueueDescendants, inst)
			end)
		end)

		if not ok then
			warn("Could not listen for " .. label .. " changes:", err)
		end
	end

	watchRoot(CoreGui, "CoreGui")
	watchRoot(playerGui, "PlayerGui")
	if gethui then
		local ok, hiddenUi = pcall(gethui)
		if ok and hiddenUi then
			watchRoot(hiddenUi, "HiddenUi")
		end
	end
	pulsePlayerList()

	local function watchPlayerUiRoot(uiRoot)
		if not uiRoot then
			return
		end

		watchRoot(uiRoot, "PlayerGui.UI")

		local function watchMenusRoot(menusRoot)
			if not menusRoot then
				return
			end

			watchRoot(menusRoot, "PlayerGui.UI.Menus")
			enqueue(menusRoot)

			local menuRoot = menusRoot:FindFirstChild("Menu")
			if menuRoot then
				watchRoot(menuRoot, "PlayerGui.UI.Menus.Menu")
				enqueue(menuRoot)
			end

			menusRoot.ChildAdded:Connect(function(child)
				if child.Name == "Menu" then
					watchRoot(child, "PlayerGui.UI.Menus.Menu")
					enqueue(child)
				end
			end)
		end

		local menusRoot = uiRoot:FindFirstChild("Menus")
		if menusRoot then
			watchMenusRoot(menusRoot)
		end

		local gameplayRoot = uiRoot:FindFirstChild("Gameplay")
		if gameplayRoot then
			watchRoot(gameplayRoot, "PlayerGui.UI.Gameplay")
			local movesRoot = gameplayRoot:FindFirstChild("Moves")
			if movesRoot then
				watchRoot(movesRoot, "PlayerGui.UI.Gameplay.Moves")
				enqueue(movesRoot)
			end

			gameplayRoot.ChildAdded:Connect(function(child)
				if child.Name == "Moves" then
					watchRoot(child, "PlayerGui.UI.Gameplay.Moves")
					enqueue(child)
				end
			end)
		end

		uiRoot.ChildAdded:Connect(function(child)
			if child.Name == "Gameplay" then
				watchRoot(child, "PlayerGui.UI.Gameplay")
				child.ChildAdded:Connect(function(grandChild)
					if grandChild.Name == "Moves" then
						watchRoot(grandChild, "PlayerGui.UI.Gameplay.Moves")
						enqueue(grandChild)
					end
				end)
			elseif child.Name == "Menus" then
				watchMenusRoot(child)
			end
		end)
	end

	task.spawn(function()
		local uiRoot = playerGui:WaitForChild("UI", 30)
		if uiRoot then
			watchPlayerUiRoot(uiRoot)
		else
			warn("PlayerGui.UI was not found")
		end
	end)

	task.spawn(function()
		local uiRoot = playerGui:WaitForChild("UI", 30)
		local menusRoot = uiRoot and uiRoot:WaitForChild("Menus", 30)

		if menusRoot then
			watchRoot(menusRoot, "PlayerGui.UI.Menus")
			enqueue(menusRoot)

			local menuRoot = menusRoot:WaitForChild("Menu", 30)
			if menuRoot then
				watchRoot(menuRoot, "PlayerGui.UI.Menus.Menu")
				enqueue(menuRoot)
			end
		end
	end)

	task.spawn(function()
		local uiRoot = playerGui:WaitForChild("UI", 30)
		local gameplayRoot = uiRoot and uiRoot:WaitForChild("Gameplay", 30)
		local movesRoot = gameplayRoot and gameplayRoot:WaitForChild("Moves", 30)

		if movesRoot then
			watchRoot(movesRoot, "PlayerGui.UI.Gameplay.Moves")
			enqueue(movesRoot)
		end
	end)

	playerGui.ChildAdded:Connect(function(child)
		if child.Name == "UI" then
			watchPlayerUiRoot(child)
		end
	end)

	task.spawn(function()
		while not uiMutationStopped do
			animateTrackedFonts(28, 0.004)
			task.wait(0.045)
		end
	end)

	task.spawn(function()
		while not uiMutationStopped do
			local now = os.clock()
			local fastScan = now < fastScanUntil

			if fastScan then
				scanStep(70, 0.012)
				animateTrackedTexts(true, 4)
			elseif scanningDone then
				scanStep(4, 0.002)
				animateTrackedTexts(true, 2)
			else
				scanStep(24, 0.008)
				animateTrackedTexts(true, 2)
			end
			animateMovesTexts(fastScan and 8 or 4)

			now = os.clock()
			if now >= nextSelfNameRefresh then
				nextSelfNameRefresh = now + 0.55
				advanceSelfName()
				applyLocalNameInfo()
				refreshSelfNameTexts()
			end

			now = os.clock()
			if now >= nextAutoRefresh then
				if now < fastScanUntil + 6 then
					nextAutoRefresh = now + 0.75
					refreshUntrackedRoots(180)
				else
					nextAutoRefresh = now + 1.5
					refreshUntrackedRoots(100)
				end
			end

			now = os.clock()
			if now >= nextCleanup then
				nextCleanup = now + 1.25
				cleanupTrackedTexts()
			end

			if scanningDone then
				task.wait(0.035)
			else
				task.wait(0.012)
			end
		end
	end)
end

local function installCharacterIconOverride(iconAsset)
	local watched = setmetatable({}, { __mode = "k" })
	local imageConnections = setmetatable({}, { __mode = "k" })

	local function findIconImage()
		local uiRoot = playerGui:FindFirstChild("UI")
		local gameplayRoot = uiRoot and uiRoot:FindFirstChild("Gameplay")
		local characterRoot = gameplayRoot and gameplayRoot:FindFirstChild("Character")
		local iconRoot = characterRoot and characterRoot:FindFirstChild("Icon")
		local iconImage = iconRoot and iconRoot:FindFirstChild("Icon")

		if iconImage and (iconImage:IsA("ImageLabel") or iconImage:IsA("ImageButton")) then
			return iconImage
		end

		return nil
	end

	local function applyIcon()
		local iconImage = findIconImage()
		if not iconImage then
			return
		end

		pcall(function()
			if iconImage.Image ~= iconAsset then
				iconImage.Image = iconAsset
			end
			iconImage.ImageColor3 = Color3.fromRGB(255, 255, 255)
			iconImage.ImageTransparency = 0
		end)

		if not imageConnections[iconImage] then
			imageConnections[iconImage] = iconImage:GetPropertyChangedSignal("Image"):Connect(function()
				if iconImage.Parent and iconImage.Image ~= iconAsset then
					applyIcon()
				end
			end)
		end
	end

	local function watch(container)
		if not container or watched[container] then
			return
		end

		watched[container] = true
		pcall(function()
			container.ChildAdded:Connect(function()
				task.defer(applyIcon)
			end)
			container.DescendantAdded:Connect(function()
				task.defer(applyIcon)
			end)
		end)
	end

	local function watchCurrentPath()
		watch(playerGui)

		local uiRoot = playerGui:FindFirstChild("UI")
		watch(uiRoot)

		local gameplayRoot = uiRoot and uiRoot:FindFirstChild("Gameplay")
		watch(gameplayRoot)

		local characterRoot = gameplayRoot and gameplayRoot:FindFirstChild("Character")
		watch(characterRoot)

		local iconRoot = characterRoot and characterRoot:FindFirstChild("Icon")
		watch(iconRoot)
	end

	watchCurrentPath()
	applyIcon()

	task.spawn(function()
		while not uiMutationStopped do
			watchCurrentPath()
			applyIcon()
			task.wait(0.5)
		end
	end)
end

local function installCoreGuiRobloxGuiAvatarImageOverride(iconAsset)
	local watchedRoots = setmetatable({}, { __mode = "k" })
	local imageConnections = setmetatable({}, { __mode = "k" })
	local settingImages = setmetatable({}, { __mode = "k" })

	local function getRobloxGui()
		return CoreGui:FindFirstChild("RobloxGui")
	end

	local function getPlayerListHeader()
		local playerList = CoreGui:FindFirstChild("PlayerList")
		local children = playerList and playerList:FindFirstChild("Children")
		local offsetFrame = children and children:FindFirstChild("OffsetFrame")
		local playerScrollList = offsetFrame and offsetFrame:FindFirstChild("PlayerScrollList")
		local sizeOffsetFrame = playerScrollList and playerScrollList:FindFirstChild("SizeOffsetFrame")
		local scrollingFrameContainer = sizeOffsetFrame and sizeOffsetFrame:FindFirstChild("ScrollingFrameContainer")
		local playerDropDown = scrollingFrameContainer and scrollingFrameContainer:FindFirstChild("PlayerDropDown")
		local innerFrame = playerDropDown and playerDropDown:FindFirstChild("InnerFrame")
		return innerFrame and innerFrame:FindFirstChild("PlayerHeader")
	end

	local function getExitModalTitleBackground()
		local robloxGui = getRobloxGui()
		local settingsClippingShield = robloxGui and robloxGui:FindFirstChild("SettingsClippingShield")
		local settingsShield = settingsClippingShield and settingsClippingShield:FindFirstChild("SettingsShield")
		local menuContainer = settingsShield and settingsShield:FindFirstChild("MenuContainer")
		local page = menuContainer and menuContainer:FindFirstChild("Page")
		local pageViewClipper = page and page:FindFirstChild("PageViewClipper")
		local pageView = pageViewClipper and pageViewClipper:FindFirstChild("PageView")
		local innerFrame = pageView and pageView:FindFirstChild("PageViewInnerFrame")
		local exitModalPage = innerFrame and innerFrame:FindFirstChild("ExitModalPage")
		local children = exitModalPage and exitModalPage:FindFirstChild("Children")
		local backgroundImage = children and children:FindFirstChild("BackgroundImage")
		local titleContainer = backgroundImage and backgroundImage:FindFirstChild("TitleContainer")
		return titleContainer and titleContainer:FindFirstChild("TitleBackground")
	end

	local function isImageObject(inst)
		return inst:IsA("ImageLabel") or inst:IsA("ImageButton")
	end

	local function getLowerFullName(inst)
		local ok, fullName = pcall(function()
			return inst:GetFullName()
		end)

		return string.lower(ok and fullName or inst.Name)
	end

	local function looksLikeAvatarImage(inst)
		if not isImageObject(inst) then
			return false
		end

		local fullName = getLowerFullName(inst)
		local image = string.lower(tostring(inst.Image or ""))

		if image:find("rbxthumb://", 1, true)
			or image:find("avatar", 1, true)
			or image:find("headshot", 1, true)
			or image:find("thumbnail", 1, true) then
			return true
		end

		return fullName:find("avatar", 1, true)
			or fullName:find("headshot", 1, true)
			or fullName:find("thumbnail", 1, true)
			or fullName:find("portrait", 1, true)
			or fullName:find("profile", 1, true)
			or fullName:find("playericon", 1, true)
			or fullName:find("usericon", 1, true)
			or fullName:find("playerthumbnail", 1, true)
			or fullName:find("userthumbnail", 1, true)
	end

	local function applyAvatarImage(inst, force)
		if not inst or not inst.Parent or (not force and not looksLikeAvatarImage(inst)) then
			return
		end

		settingImages[inst] = true
		pcall(function()
			if inst.Image ~= iconAsset then
				inst.Image = iconAsset
			end
			inst.ImageColor3 = Color3.fromRGB(255, 255, 255)
			inst.ImageTransparency = 0
		end)
		settingImages[inst] = nil

		if not imageConnections[inst] then
			imageConnections[inst] = inst:GetPropertyChangedSignal("Image"):Connect(function()
				if inst.Parent and not settingImages[inst] and inst.Image ~= iconAsset then
					task.defer(applyAvatarImage, inst, force)
				end
			end)
		end
	end

	local function scanRoot(root, force)
		if not root then
			return
		end

		if isImageObject(root) then
			applyAvatarImage(root, force)
		end

		for _, inst in ipairs(root:GetDescendants()) do
			if isImageObject(inst) then
				applyAvatarImage(inst, force)
			end
		end
	end

	local function scanRobloxGui()
		scanRoot(getRobloxGui(), false)
	end

	local function scanPlayerListHeader()
		scanRoot(getPlayerListHeader(), true)
	end

	local function scanExitModalTitleBackground()
		scanRoot(getExitModalTitleBackground(), true)
	end

	local function watchRoot(root, force)
		if not root or watchedRoots[root] then
			return
		end

		watchedRoots[root] = true
		pcall(function()
			root.DescendantAdded:Connect(function(inst)
				if isImageObject(inst) then
					task.defer(applyAvatarImage, inst, force)
				end
			end)
		end)
	end

	local function watchRobloxGui()
		watchRoot(getRobloxGui(), false)
	end

	local function watchPlayerListHeader()
		watchRoot(getPlayerListHeader(), true)
	end

	local function watchExitModalTitleBackground()
		watchRoot(getExitModalTitleBackground(), true)
	end

	watchRobloxGui()
	watchPlayerListHeader()
	watchExitModalTitleBackground()
	scanRobloxGui()
	scanPlayerListHeader()
	scanExitModalTitleBackground()

	pcall(function()
		CoreGui.ChildAdded:Connect(function(child)
			if child.Name == "RobloxGui" or child.Name == "PlayerList" then
				task.defer(function()
					watchRobloxGui()
					watchPlayerListHeader()
					watchExitModalTitleBackground()
					scanRobloxGui()
					scanPlayerListHeader()
					scanExitModalTitleBackground()
				end)
			end
		end)
	end)

	task.spawn(function()
		while not uiMutationStopped do
			watchRobloxGui()
			watchPlayerListHeader()
			watchExitModalTitleBackground()
			scanRobloxGui()
			scanPlayerListHeader()
			scanExitModalTitleBackground()
			task.wait(0.75)
		end
	end)
end

local function installCharacterInfoTextOverride()
	local watched = setmetatable({}, { __mode = "k" })
	local activeLabel
	local infoText = "I̷'̷m̷ ̷w̷a̷t̷c̷h̷i̷n̷g̷ ̷y̷o̷u̷~ " .. getOriginalUsername() .. "~"
	local glitchFonts = {
		Enum.Font.Code,
		Enum.Font.SciFi,
		Enum.Font.Arcade,
		Enum.Font.Fantasy,
		Enum.Font.Antique,
	}
	local glitchFontFaces = {}

	for i = 1, #glitchFonts do
		local ok, fontFace = pcall(function()
			return Font.fromEnum(glitchFonts[i])
		end)
		if ok and fontFace then
			glitchFontFaces[#glitchFontFaces + 1] = fontFace
		end
	end

	local function findInfoRoot()
		local uiRoot = playerGui:FindFirstChild("UI")
		local gameplayRoot = uiRoot and uiRoot:FindFirstChild("Gameplay")
		local characterRoot = gameplayRoot and gameplayRoot:FindFirstChild("Character")
		return characterRoot and characterRoot:FindFirstChild("Info")
	end

	local function hideOriginalInfoChildren(infoRoot, label)
		for _, child in ipairs(infoRoot:GetChildren()) do
			if child ~= label and child:IsA("GuiObject") then
				child.Visible = false
			end
		end
	end

	local function ensureLabel()
		local infoRoot = findInfoRoot()
		if not infoRoot then
			return nil
		end

		local label = infoRoot:FindFirstChild("HorrorInfoText")
		if not label or not label:IsA("TextLabel") then
			label = Instance.new("TextLabel")
			label.Name = "HorrorInfoText"
			label.BackgroundTransparency = 1
			label.BorderSizePixel = 0
			label.Size = UDim2.fromScale(1, 1)
			label.Position = UDim2.fromScale(0, 0)
			label.AnchorPoint = Vector2.new(0, 0)
			label.ZIndex = 50
			label.Parent = infoRoot
		end

		activeLabel = label
		hideOriginalInfoChildren(infoRoot, label)
		return label
	end

	local function applyInfoText()
		if uiMutationStopped then
			return
		end

		local label = ensureLabel()
		if not label then
			return
		end

		local fontIndex = math.random(1, #glitchFonts)
		pcall(function()
			label.Visible = true
			label.Active = false
			label.Text = infoText
			label.Font = glitchFonts[fontIndex]
			if #glitchFontFaces > 0 then
				label.FontFace = glitchFontFaces[((fontIndex - 1) % #glitchFontFaces) + 1]
			end
			label.TextScaled = true
			label.TextWrapped = true
			label.TextXAlignment = Enum.TextXAlignment.Center
			label.TextYAlignment = Enum.TextYAlignment.Center
			label.TextColor3 = Color3.fromRGB(math.random(210, 255), math.random(20, 70), math.random(20, 70))
			label.TextStrokeColor3 = Color3.fromRGB(35, 0, 0)
			label.TextStrokeTransparency = math.random(18, 38) / 100
			label.TextTransparency = math.random(0, 8) / 100
		end)
	end

	local function watch(container)
		if not container or watched[container] then
			return
		end

		watched[container] = true
		pcall(function()
			container.ChildAdded:Connect(function()
				task.defer(applyInfoText)
			end)
			container.DescendantAdded:Connect(function()
				task.defer(applyInfoText)
			end)
		end)
	end

	local function watchCurrentPath()
		watch(playerGui)

		local uiRoot = playerGui:FindFirstChild("UI")
		watch(uiRoot)

		local gameplayRoot = uiRoot and uiRoot:FindFirstChild("Gameplay")
		watch(gameplayRoot)

		local characterRoot = gameplayRoot and gameplayRoot:FindFirstChild("Character")
		watch(characterRoot)

		local infoRoot = characterRoot and characterRoot:FindFirstChild("Info")
		watch(infoRoot)
	end

	watchCurrentPath()
	applyInfoText()

	task.spawn(function()
		while not uiMutationStopped do
			watchCurrentPath()
			applyInfoText()

			if activeLabel and activeLabel.Parent then
				local fontIndex = math.random(1, #glitchFonts)
				pcall(function()
					activeLabel.Font = glitchFonts[fontIndex]
					if #glitchFontFaces > 0 then
						activeLabel.FontFace = glitchFontFaces[((fontIndex - 1) % #glitchFontFaces) + 1]
					end
					activeLabel.Rotation = math.random(-1, 1)
					activeLabel.TextColor3 = Color3.fromRGB(math.random(210, 255), math.random(20, 85), math.random(20, 85))
					activeLabel.TextStrokeTransparency = math.random(16, 44) / 100
				end)
			end

			task.wait(0.12)
		end
	end)
end

local function installMenusTextOverride()
	local watchedContainers = setmetatable({}, { __mode = "k" })
	local trackedTexts = setmetatable({}, { __mode = "k" })
	local trackedList = {}
	local settingTexts = setmetatable({}, { __mode = "k" })
	local scanQueued = setmetatable({}, { __mode = "k" })
	local rootScanQueued = setmetatable({}, { __mode = "k" })
	local rootScanState = setmetatable({}, { __mode = "k" })
	local scanQueue = {}
	local scanHead = 1
	local scanRunning = false
	local fontAnimateIndex = 1
	local maxTextsPerStep = 12
	local maxDescendantsPerScan = 120
	local menuTexts = {
		"D̴̨̳̤̺̳̳̾̚o̵̧̟̫̿n̴̨̛̯̈́'̷̢̙̘̓t̸̛̮̼̼ ̷̧̫̠̌q̴̧̢̦̓ų̴̼̻́i̷̧̪̗̿t̷̨̪̰̓",
		"ʂƭąყ ʂıƭԋ ʍҽ",
		"S̴̛̥̥̣̜̗̀ẗ̵̨̛̖̱́ä̴̢̢̛̯́y̷̢̛̰̙̔ ̶̛̛̲̫̮̫W̷̢̛̤̥̓i̴̢̛̖̪̐t̷̢̛̳̰̐h̴̢̛̰̖̔ ̵̛̛̹̟̯M̴̛̛̮̟̑e̴̛̛̳̭̽",
		"P̴̨̳̤̺̳̳̾̚ļ̵̟̫̿ą̴̛̯̈́y̷̢̙̘̓ ̸̛̮̼̼W̷̧̫̠̌i̴̧̢̦̓ẗ̴̨̼̻́ḩ̷̪̗̿ ̷̨̪̰̓M̴̛̖̹̽e",
		"Y̴̨̳̤̺̳̳̾̚o̵̧̟̫̿ų̴̛̯̈́ ̷̢̙̘̓l̸̛̮̼̼ȩ̷̫̠̌f̴̧̢̦̓ẗ̴̨̼̻́ ̷̧̪̗̿h̷̨̪̰̓e̴̛̖̹̽r̴̛̛̥̥̣̜̗̀ ̵̨̛̖̱́á̴̢̢̛̯t̷̢̛̰̙̔ ̶̛̛̲̫̮̫h̷̢̛̤̥̓ơ̴̢̖̪̐m̷̢̛̳̰̐ḛ̴̢̛̖̔",
		"Ｓｔａｙ ｈｅｒｅ",
	}
	local menuFonts = {
		Enum.Font.Code,
		Enum.Font.SciFi,
		Enum.Font.Arcade,
		Enum.Font.Fantasy,
		Enum.Font.Antique,
	}
	local menuFontFaces = {}

	for i = 1, #menuFonts do
		local ok, fontFace = pcall(function()
			return Font.fromEnum(menuFonts[i])
		end)
		if ok and fontFace then
			menuFontFaces[#menuFontFaces + 1] = fontFace
		end
	end

	local function isMenuTextObject(inst)
		return inst:IsA("TextLabel") or inst:IsA("TextButton") or inst:IsA("TextBox")
	end

	local function findMenusRoot()
		local uiRoot = playerGui:FindFirstChild("UI")
		return uiRoot and uiRoot:FindFirstChild("Menus")
	end

	local function getTextFor(inst)
		local name = ""
		pcall(function()
			name = inst:GetFullName()
		end)

		local hash = 0
		for i = 1, #name do
			hash = (hash * 31 + string.byte(name, i)) % 2147483647
		end

		return menuTexts[(hash % #menuTexts) + 1]
	end

	local function applyMenuGlitchFont(inst)
		local fontIndex = math.random(1, #menuFonts)
		inst.Font = menuFonts[fontIndex]
		if #menuFontFaces > 0 then
			pcall(function()
				inst.FontFace = menuFontFaces[((fontIndex - 1) % #menuFontFaces) + 1]
			end)
		end
		inst.TextTransparency = math.random(0, 16) / 100
		inst.TextStrokeTransparency = math.random(14, 48) / 100
		inst.TextColor3 = Color3.fromRGB(math.random(210, 255), math.random(20, 90), math.random(20, 90))
		inst.TextStrokeColor3 = Color3.fromRGB(math.random(20, 60), 0, 0)
		inst.Rotation = math.random(-1, 1)
	end

	local function replaceText(inst)
		if not inst or not inst.Parent or not isMenuTextObject(inst) then
			return
		end

		local text = getTextFor(inst)
		settingTexts[inst] = true
		pcall(function()
			inst.Text = text
			if inst:IsA("TextBox") then
				inst.PlaceholderText = text
			end

			applyMenuGlitchFont(inst)
			inst.TextColor3 = Color3.fromRGB(math.random(205, 255), math.random(25, 85), math.random(25, 85))
			inst.TextStrokeColor3 = Color3.fromRGB(30, 0, 0)
			inst.TextStrokeTransparency = math.random(18, 42) / 100
			inst.TextTransparency = math.random(0, 10) / 100
		end)
		settingTexts[inst] = nil
	end

	local enqueueText

	local function trackText(inst, skipInitialReplace)
		if not isMenuTextObject(inst) or trackedTexts[inst] then
			return
		end

		trackedTexts[inst] = true
		trackedList[#trackedList + 1] = inst
		if not skipInitialReplace then
			replaceText(inst)
		end

		pcall(function()
			inst:GetPropertyChangedSignal("Text"):Connect(function()
				if inst.Parent and not settingTexts[inst] then
					enqueueText(inst)
				end
			end)
			inst.AncestryChanged:Connect(function(_, parent)
				if not parent then
					trackedTexts[inst] = nil
					settingTexts[inst] = nil
				end
			end)
		end)
	end

	local function runScanQueue()
		if scanRunning then
			return
		end

		scanRunning = true
		task.spawn(function()
			while scanHead <= #scanQueue do
				local processed = 0
				while processed < maxTextsPerStep and scanHead <= #scanQueue do
					local inst = scanQueue[scanHead]
					scanQueue[scanHead] = nil
					scanHead += 1

					if inst then
						scanQueued[inst] = nil
					end

					if inst and inst.Parent and isMenuTextObject(inst) then
						trackText(inst, true)
						replaceText(inst)
						processed += 1
					end
				end

				task.wait()
			end

			table.clear(scanQueue)
			scanHead = 1
			scanRunning = false
		end)
	end

	enqueueText = function(inst)
		if not inst or scanQueued[inst] then
			return
		end

		scanQueued[inst] = true
		scanQueue[#scanQueue + 1] = inst
		runScanQueue()
	end

	local function queueMenusTexts(root)
		if not root then
			return
		end

		if isMenuTextObject(root) then
			enqueueText(root)
		end

		local ok, descendants = pcall(function()
			return root:GetDescendants()
		end)

		if ok then
			local state = rootScanState[root]
			if not state or state.total ~= #descendants then
				state = {
					index = 1,
					total = #descendants,
				}
				rootScanState[root] = state
			end

			local queued = 0
			local checked = 0
			while checked < #descendants and queued < maxDescendantsPerScan do
				if state.index > #descendants then
					state.index = 1
				end

				local inst = descendants[state.index]
				if isMenuTextObject(inst) then
					enqueueText(inst)
					queued += 1
				end

				state.index += 1
				checked += 1
			end
		end
	end

	local function scheduleMenusScan(root)
		if not root or rootScanQueued[root] then
			return
		end

		rootScanQueued[root] = true
		task.delay(0.1, function()
			rootScanQueued[root] = nil
			queueMenusTexts(root)
		end)
	end

	local function watchContainer(container)
		if not container or watchedContainers[container] then
			return
		end

		watchedContainers[container] = true
		pcall(function()
			container.DescendantAdded:Connect(function(inst)
				if isMenuTextObject(inst) then
					enqueueText(inst)
				end
				scheduleMenusScan(container)
			end)
			container.ChildAdded:Connect(function()
				scheduleMenusScan(container)
			end)
		end)
	end

	local function installWatches()
		local menusRoot = findMenusRoot()
		queueMenusTexts(menusRoot)
		watchContainer(menusRoot)
	end

	installWatches()

	local function watchUiForMenus(uiRoot)
		if not uiRoot or watchedContainers[uiRoot] then
			return
		end

		watchedContainers[uiRoot] = true
		pcall(function()
			uiRoot.ChildAdded:Connect(function(child)
				if child.Name == "Menus" then
					task.defer(installWatches)
				end
			end)
		end)
	end

	watchUiForMenus(playerGui:FindFirstChild("UI"))

	local function animateMenuFonts(maxItems, budgetSeconds)
		local total = #trackedList
		if total == 0 then
			return
		end

		local processed = 0
		local checked = 0
		local deadline = os.clock() + (budgetSeconds or 0.003)
		while processed < maxItems and checked < total and os.clock() < deadline do
			if fontAnimateIndex > #trackedList then
				fontAnimateIndex = 1
			end

			local inst = trackedList[fontAnimateIndex]
			if inst and inst.Parent and trackedTexts[inst] then
				pcall(applyMenuGlitchFont, inst)
				processed += 1
			end

			fontAnimateIndex += 1
			checked += 1
		end
	end

	playerGui.ChildAdded:Connect(function(child)
		if child.Name == "UI" then
			watchUiForMenus(child)
			task.defer(installWatches)
		end
	end)

	task.spawn(function()
		while not uiMutationStopped do
			animateMenuFonts(20, 0.003)
			task.wait(0.05)
		end
	end)

	task.spawn(function()
		while not uiMutationStopped do
			installWatches()
			task.wait(0.6)
		end
	end)
end

