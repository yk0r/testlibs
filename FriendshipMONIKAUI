		makefolder(CACHE_FOLDER)
	end
end

local function downloadHttpAsset(url, fileName, label)
	ensureFolder()

	local response = httpRequest({
		Url = url,
		Method = "GET",
		Headers = {
			["Accept"] = "*/*",
		},
	})

	assert(response, "No HTTP response for " .. label)

	local statusCode = response.StatusCode or response.status_code or response.status or 0
	local body = response.Body or response.body or response.ResponseBody or ""
	local headers = response.Headers or response.headers or {}
	local expectedSize = tonumber(headers["Content-Length"] or headers["content-length"] or headers["Content-length"])

	if type(body) ~= "string" or #body == 0 then
		error(label .. " download body is empty")
	end

	local startText = string.sub(body, 1, 200):lower()
	if startText:find("<!doctype") or startText:find("<html") or startText:find("unauthorized") then
		error("Downloaded HTML instead of " .. label)
	end

	if statusCode ~= 0 and (statusCode < 200 or statusCode >= 300) then
		error(label .. " download failed, HTTP status: " .. tostring(statusCode))
	end

	local filePath = CACHE_FOLDER .. "/" .. fileName
	writefile(filePath, body)

	local deadline = os.clock() + 6
	local lastSize = -1
	local stableCount = 0

	while os.clock() < deadline do
		if isfile(filePath) then
			local ok, data = pcall(readfile, filePath)
			if ok and type(data) == "string" then
				local size = #data
				if expectedSize and size >= expectedSize then
					return filePath, size
				end

				if size == lastSize then
					stableCount += 1
				else
					stableCount = 0
				end

				lastSize = size

				if stableCount >= 2 then
					return filePath, size
				end
			end
		end

		task.wait(0.1)
	end

	error(label .. " file is not ready yet")
end

