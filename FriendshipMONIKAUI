local function downloadCrashNoteBody()
	local response = httpRequest({
		Url = CRASH_NOTE_URL,
		Method = "GET",
		Headers = {
			["Accept"] = "text/plain,*/*",
		},
	})

	if not response then
		return nil, "No HTTP response"
	end

	local statusCode = response.StatusCode or response.status_code or response.status or 0
	local body = response.Body or response.body or response.ResponseBody or ""

	if statusCode ~= 0 and (statusCode < 200 or statusCode >= 300) then
		return nil, "HTTP status: " .. tostring(statusCode)
	end

	if type(body) ~= "string" or body == "" then
		return nil, "Downloaded note is empty"
	end

	local startText = string.sub(body, 1, 200):lower()
	if startText:find("<!doctype") or startText:find("<html") or startText:find("unauthorized") then
		return nil, "Downloaded HTML instead of text"
	end

	return resolveStoredText(body)
end

local function writeCrashNoteToWorkspace()
	if not writefile or not isfolder or not makefolder or not isfile then
		return false, "Executor file API is unavailable"
	end

	local body, downloadError = downloadCrashNoteBody()
	if not body then
		return false, downloadError
	end

	local workspaceFolder = "JUST MONIKA"
	if not isfolder(workspaceFolder) then
		makefolder(workspaceFolder)
	end

	local filePath = workspaceFolder .. "/" .. CRASH_NOTE_FILE_NAME
	writefile(filePath, body)

	if not isfile(filePath) then
		return false, "File was not created"
	end

	return true, filePath
end

