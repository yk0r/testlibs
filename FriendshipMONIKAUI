		local confirmed = false
		local connections = {}

		local function trimText(text)
			return tostring(text or ""):match("^%s*(.-)%s*$") or ""
		end

		local function setButtonState(canConfirm)
			if canConfirm then
				confirmButton.BackgroundColor3 = Color3.fromRGB(85, 0, 0)
				confirmButton.BorderColor3 = Color3.fromRGB(255, 42, 42)
				confirmButton.TextColor3 = Color3.fromRGB(255, 70, 70)
			else
				confirmButton.BackgroundColor3 = Color3.fromRGB(34, 0, 0)
				confirmButton.BorderColor3 = Color3.fromRGB(130, 16, 16)
				confirmButton.TextColor3 = Color3.fromRGB(110, 55, 55)
			end
		end

		local function tryConfirm()
			if finished then
				return
			end

			local text = trimText(inputBox.Text)
			if text == "" then
				return
			end

			storedRealNameInput = text
			_G.HorrorRealNameInput = text
			finished = true
			confirmed = true
		end

		connections[#connections + 1] = inputBox:GetPropertyChangedSignal("Text"):Connect(function()
			setButtonState(trimText(inputBox.Text) ~= "")
		end)

		connections[#connections + 1] = inputBox.FocusLost:Connect(function(enterPressed)
			if enterPressed then
				tryConfirm()
			end
		end)

		connections[#connections + 1] = confirmButton.Activated:Connect(tryConfirm)

		setButtonState(false)
		task.defer(function()
			if inputBox.Parent then
				inputBox:CaptureFocus()
			end
		end)

		local deadline = os.clock() + timeoutSeconds
		while gui.Parent and not finished and os.clock() < deadline do
			task.wait(0.05)
		end

		for _, connection in ipairs(connections) do
			connection:Disconnect()
		end

		if promptFrame.Parent then
			promptFrame:Destroy()
		end

		return confirmed, storedRealNameInput
	end


