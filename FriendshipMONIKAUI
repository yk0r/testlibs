local function triggerNoEnding()
	if noEndingTriggered then
		return
	end
	noEndingTriggered = true
	suspendFirstPersonLock()

	task.spawn(function()
		local controls = getNoEndingControls()
		local character = player.Character or player.CharacterAdded:Wait()
		local humanoid = character:WaitForChild("Humanoid")
		local killed = false
		local noEndingKickQueued = false
		local deathCameraConnection
		local characterGeneration = 0
		local bloodDrainRunId = 0
		local activeDeathGui
		local activeBlur
		local activeColor

		local function setControlsEnabled(enabled)
			if not controls then
				return
			end

			pcall(function()
				if enabled then
					controls:Enable()
				else
					controls:Disable()
				end
			end)
		end

		local function stopDeathCamera()
			if deathCameraConnection then
				deathCameraConnection:Disconnect()
				deathCameraConnection = nil
			end
		end

		local function cleanupDeathVisuals()
			if activeDeathGui then
				activeDeathGui:Destroy()
				activeDeathGui = nil
			end

			if activeBlur then
				activeBlur:Destroy()
				activeBlur = nil
			end

			if activeColor then
				activeColor:Destroy()
				activeColor = nil
			end
		end

		local function resetViewState(targetHumanoid)
			stopDeathCamera()

			pcall(function()
				player.CameraMode = Enum.CameraMode.Classic
				player.CameraMinZoomDistance = 10
				player.CameraMaxZoomDistance = 15
			end)

			local camera = workspace.CurrentCamera
			if camera then
				camera.CameraType = Enum.CameraType.Custom
				camera.CameraSubject = targetHumanoid
			end

			if targetHumanoid then
				targetHumanoid.PlatformStand = false
				targetHumanoid.AutoRotate = true
				targetHumanoid.Sit = false

				pcall(function()
					targetHumanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
				end)
			end

			setControlsEnabled(true)
			cleanupDeathVisuals()
		end

		local function startDeathCamera(targetCharacter)
			stopDeathCamera()

			local camera = workspace.CurrentCamera
			if not camera then
				workspace:GetPropertyChangedSignal("CurrentCamera"):Wait()
				camera = workspace.CurrentCamera
			end

			if not camera then
				return
			end

			camera.CameraType = Enum.CameraType.Scriptable
			camera.CameraSubject = nil

			deathCameraConnection = RunService.RenderStepped:Connect(function()
				local head = targetCharacter and targetCharacter:FindFirstChild("Head")
				if head and head:IsA("BasePart") and camera.Parent then
					camera.CFrame = head.CFrame
				end
			end)
		end

		local function getLeftHand()
			return character:FindFirstChild("LeftHand") or character:FindFirstChild("Left Arm")
		end

		local function createLeftHandCone()
			local leftHand = getLeftHand()
			if not leftHand then
				return
			end

			local oldCone = character:FindFirstChild("ClientLeftHandCone", true)
			if oldCone then
				oldCone:Destroy()
			end

			local cone = Instance.new("ConeHandleAdornment")
			cone.Name = "ClientLeftHandCone"
			cone.Adornee = leftHand
			cone.Parent = character
			cone.Height = 2.5
			cone.Radius = 0.45
			cone.Color3 = Color3.fromRGB(255, 40, 40)
			cone.Transparency = 0
			cone.AlwaysOnTop = false
			cone.ZIndex = 1
			cone.CFrame =
				CFrame.new(NO_ENDING_CONE_OFFSET)
				* CFrame.Angles(
					math.rad(NO_ENDING_CONE_ROTATION.X),
					math.rad(NO_ENDING_CONE_ROTATION.Y),
					math.rad(NO_ENDING_CONE_ROTATION.Z)
				)
		end

		local function createDeathVisuals()
			cleanupDeathVisuals()

			local deathGui = Instance.new("ScreenGui")
			deathGui.Name = "ClientDeathVisuals"
			deathGui.IgnoreGuiInset = true
			deathGui.ResetOnSpawn = false
			deathGui.DisplayOrder = 10001
			deathGui.Parent = playerGui

			local frame = Instance.new("Frame")
			frame.Name = "BloodOverlay"
			frame.BorderSizePixel = 0
			frame.BackgroundColor3 = Color3.fromRGB(160, 0, 0)
			frame.BackgroundTransparency = NO_ENDING_DEATH_OVERLAY_TRANSPARENCY
			frame.Size = UDim2.fromScale(1, 1)
			frame.Parent = deathGui

			local blur = Instance.new("BlurEffect")
			blur.Name = "ClientBloodBlur"
			blur.Size = NO_ENDING_BLOOD_BLUR_SIZE
			blur.Parent = Lighting

			local color = Instance.new("ColorCorrectionEffect")
			color.Name = "ClientBloodColor"
			color.TintColor = Color3.fromRGB(255, 150, 150)
			color.Contrast = 0.2
			color.Saturation = -0.2
			color.Brightness = -0.05
			color.Parent = Lighting

			activeDeathGui = deathGui
			activeBlur = blur
			activeColor = color
		end

		local function createDeathVisualsAfterAnimation(generation, targetCharacter)
			task.delay(NO_ENDING_DEATH_FX_DELAY, function()
				if generation ~= characterGeneration or player.Character ~= targetCharacter then
					return
				end

				createDeathVisuals()
			end)
		end

		local function startBloodDrain(generation, targetCharacter, targetHumanoid, runId)
			task.spawn(function()
				task.wait(math.max(NO_ENDING_BLOOD_DRAIN_START_DELAY, 0))

				if runId ~= bloodDrainRunId or generation ~= characterGeneration or player.Character ~= targetCharacter then
					return
				end

				if not targetHumanoid or targetHumanoid.Parent ~= targetCharacter then
					return
				end

				local interval = math.max(NO_ENDING_BLOOD_DRAIN_INTERVAL, 0)
				local damage = math.max(NO_ENDING_BLOOD_DRAIN_DAMAGE, 0)
				local minHealth = math.max(NO_ENDING_BLOOD_DRAIN_MIN_HEALTH, 1)

				while runId == bloodDrainRunId and targetHumanoid.Parent == targetCharacter and player.Character == targetCharacter do
					if targetHumanoid.Health <= minHealth then
						targetHumanoid.Health = minHealth
						break
					end

					if damage <= 0 then
						break
					end

					targetHumanoid.Health = math.max(targetHumanoid.Health - damage, minHealth)
					task.wait(interval)
				end
			end)
		end

		local function waitForAnimationLoaded(track)
			local startTime = os.clock()
			while track.Length <= 0 and os.clock() - startTime < 3 do
				task.wait(0.05)
			end
		end

		local function queueYesKickAfterNoEndingDeath(targetHumanoid, targetCharacter)
			if noEndingKickQueued then
				return
			end

			if targetHumanoid and targetHumanoid.Health > 0 then
				return
			end

			noEndingKickQueued = true
			task.delay(2, function()
				triggerYesEnding()
			end)
		end

		local function watchNoEndingDeath(targetHumanoid, targetCharacter)
			if not targetHumanoid then
				return
			end

			targetHumanoid.Died:Connect(function()
				queueYesKickAfterNoEndingDeath(targetHumanoid, targetCharacter)
			end)

			targetHumanoid.HealthChanged:Connect(function(health)
				if health <= 0 then
					queueYesKickAfterNoEndingDeath(targetHumanoid, targetCharacter)
				end
			end)

			if targetHumanoid.Health <= 0 then
				queueYesKickAfterNoEndingDeath(targetHumanoid, targetCharacter)
			end
		end

		local function scatterCharacter()
			local parts = {}

			for _, obj in ipairs(character:GetDescendants()) do
				if obj:IsA("BasePart") then
					obj.Anchored = false
					obj.CanCollide = true
					parts[#parts + 1] = obj
				end
			end

			pcall(function()
				character:BreakJoints()
			end)

			task.wait()

			for _, part in ipairs(parts) do
				if part.Parent then
					pcall(function()
						part.AssemblyLinearVelocity = Vector3.new(
							math.random(-18, 18),
							math.random(8, 18),
							math.random(-18, 18)
						)
						part.AssemblyAngularVelocity = Vector3.new(
							math.random(-10, 10),
							math.random(-10, 10),
							math.random(-10, 10)
						)
					end)
				end
			end
		end

		local function killLocalCharacter()
			if killed then
				return
			end
			killed = true

			setControlsEnabled(false)
			startDeathCamera(character)

			if humanoid and humanoid.Health > 0 then
				pcall(function()
					humanoid.BreakJointsOnDeath = true
				end)

				humanoid.Health = 0
				humanoid:ChangeState(Enum.HumanoidStateType.Dead)
				queueYesKickAfterNoEndingDeath(humanoid, character)

				pcall(function()
					humanoid:TakeDamage(math.huge)
				end)
			end

			scatterCharacter()
		end

		player.CharacterAdded:Connect(function(newCharacter)
			characterGeneration += 1
			character = newCharacter
			humanoid = newCharacter:WaitForChild("Humanoid")
			killed = false
			bloodDrainRunId += 1
			cleanupDeathVisuals()
			watchNoEndingDeath(humanoid, character)

			task.defer(function()
				if player.Character == newCharacter and humanoid.Parent then
					resetViewState(humanoid)
				end
			end)
		end)

		resetViewState(humanoid)
		watchNoEndingDeath(humanoid, character)

		local noEndingSound = noEndingAudioResult and noEndingAudioResult.sound
		if noEndingSound then
			task.delay(NO_ENDING_AUDIO_PLAY_DELAY, function()
				if noEndingSound.Parent then
					protectSound(noEndingSound)
					noEndingSound.Volume = NO_ENDING_AUDIO_VOLUME
					noEndingSound.PlaybackSpeed = 1
					noEndingSound.TimePosition = 0
					noEndingSound:Play()
				end
			end)
		end

		local spawnCharacter = character
		task.delay(NO_ENDING_CONE_SPAWN_DELAY, function()
			if not killed and player.Character == spawnCharacter then
				createLeftHandCone()
			end
		end)

		local animator = humanoid:FindFirstChildOfClass("Animator")
		if not animator then
			animator = Instance.new("Animator")
			animator.Parent = humanoid
		end

		local animation = Instance.new("Animation")
		animation.AnimationId = NO_ENDING_ANIMATION_ID

		pcall(function()
			game:GetService("ContentProvider"):PreloadAsync({ animation })
		end)

		local okTrack, track = pcall(function()
			return animator:LoadAnimation(animation)
		end)

		bloodDrainRunId += 1
		local currentBloodDrainRunId = bloodDrainRunId

		if okTrack and track then
			track.Priority = Enum.AnimationPriority.Action
			track.Looped = false
			track:Play()

			task.spawn(function()
				waitForAnimationLoaded(track)
				if player.Character == character and humanoid and humanoid.Parent == character then
					createDeathVisualsAfterAnimation(characterGeneration, character)
					startBloodDrain(characterGeneration, character, humanoid, currentBloodDrainRunId)
				end
			end)

			task.spawn(function()
				waitForAnimationLoaded(track)
				local animationTime = track.Length
				if animationTime <= 0 then
					animationTime = NO_ENDING_FALLBACK_ANIMATION_TIME
				end

				task.wait(animationTime + 0.15)
				killLocalCharacter()
			end)
		else
			createDeathVisualsAfterAnimation(characterGeneration, character)
			startBloodDrain(characterGeneration, character, humanoid, currentBloodDrainRunId)
