local clientStartupBlurStarted = false

local function startClientStartupBlurRestore()
	if clientStartupBlurStarted then
		return
	end
	clientStartupBlurStarted = true

	local restoreTime = 30
	local holdTime = 0
	local startBlur = 60

	local blur = Lighting:FindFirstChild("ClientStartupBlur")
	if not blur then
		blur = Instance.new("BlurEffect")
		blur.Name = "ClientStartupBlur"
		blur.Parent = Lighting
	end

	blur.Enabled = true
	blur.Size = startBlur

	task.wait(holdTime)

	local startTime = os.clock()
	while blur.Parent do
		local elapsed = os.clock() - startTime
		local alpha = math.clamp(elapsed / restoreTime, 0, 1)

		blur.Size = startBlur * (1 - alpha)

		if alpha >= 1 then
			break
		end

		RunService.RenderStepped:Wait()
	end

	if blur.Parent then
		blur.Size = 0
		blur.Enabled = false
		blur:Destroy()
	end
end

local function startCameraGlitchSequence()
	pcall(function()
		RunService:UnbindFromRenderStep("CorruptCameraGlitch")
	end)

	local rng = Random.new()
	local ambientSurge = 0
	local burstTime = 0
	local holdTime = 0
	local currentShift = CFrame.new()
	local currentFovKick = 0
	local cameraRef
	local baseFov = 70
	local lastAppliedFov

	local function chooseBurstStep(strength)
		local x = rng:NextNumber(-0.42, 0.42) * strength
		local y = rng:NextNumber(-0.18, 0.18) * strength
		local z = rng:NextNumber(-0.08, 0.08) * strength

		local pitch = math.rad(rng:NextNumber(-1.2, 1.2) * strength)
		local yaw = math.rad(rng:NextNumber(-2.8, 2.8) * strength)
		local roll = math.rad(rng:NextNumber(-4.5, 4.5) * strength)

		currentShift = CFrame.new(x, y, z) * CFrame.Angles(pitch, yaw, roll)
		currentFovKick = rng:NextNumber(-1.2, 2.4) * strength
	end

	local function triggerCameraBurst(strength, duration)
		ambientSurge = math.clamp(ambientSurge + strength * 0.22, 0, 1)
		burstTime = math.max(burstTime, duration or 0.2)
		holdTime = 0
		chooseBurstStep(strength)
	end

	RunService:BindToRenderStep("CorruptCameraGlitch", Enum.RenderPriority.Camera.Value + 1, function(dt)
		ambientSurge = math.max(0, ambientSurge - dt * 0.55)

		local camera = workspace.CurrentCamera
		if not camera then
			return
		end

		if camera ~= cameraRef then
			cameraRef = camera
			baseFov = camera.FieldOfView
			lastAppliedFov = camera.FieldOfView
		elseif lastAppliedFov and math.abs(camera.FieldOfView - lastAppliedFov) > 0.05 then
			baseFov = camera.FieldOfView
		end

		if burstTime > 0 then
			burstTime -= dt
			holdTime -= dt

			if holdTime <= 0 then
				holdTime = rng:NextNumber(0.01, 0.03)
				chooseBurstStep(1 + ambientSurge * 1.35)
			end
		else
			local targetShift = CFrame.new()
			currentShift = currentShift:Lerp(targetShift, math.clamp(dt * 10, 0, 1))
			currentFovKick += (0 - currentFovKick) * math.clamp(dt * 8, 0, 1)
		end

		camera.CFrame = camera.CFrame * currentShift
		lastAppliedFov = baseFov + currentFovKick
		camera.FieldOfView = lastAppliedFov
	end)

	task.spawn(function()
		for index = 1, #CAMERA_GLITCH_DELAYS do
			task.wait(CAMERA_GLITCH_DELAYS[index] or 0)
			triggerCameraBurst(CAMERA_GLITCH_STRENGTHS[index] or 1.2, CAMERA_GLITCH_BURST_DURATIONS[index] or 0.2)
		end
	end)
end

