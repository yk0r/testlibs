local function waitForPlayerLoaded()
	if not game:IsLoaded() then
		game.Loaded:Wait()
	end

	playerGui = player:WaitForChild("PlayerGui")

	local character = player.Character or player.CharacterAdded:Wait()
	local humanoid = character:WaitForChild("Humanoid")
	character:WaitForChild("HumanoidRootPart")
	character:WaitForChild("Head")

	if humanoid.RigType == Enum.HumanoidRigType.R15 then
		character:WaitForChild("UpperTorso")
		character:WaitForChild("LowerTorso")
	else
		character:WaitForChild("Torso")
	end

	local appearanceLoaded = false
	local connection
	connection = player.CharacterAppearanceLoaded:Connect(function(loadedCharacter)
		if loadedCharacter == character then
			appearanceLoaded = true
			if connection then
				connection:Disconnect()
			end
		end
	end)

	local deadline = os.clock() + 8
	while character.Parent and not appearanceLoaded and os.clock() < deadline do
		task.wait(0.1)
	end

	if connection then
		connection:Disconnect()
	end

	task.wait(0.2)
	return character, humanoid
end

