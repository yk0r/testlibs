	local function splitTextUnits(text)
		local units = {}
		local ok = pcall(function()
			for first, last in utf8.graphemes(text) do
				units[#units + 1] = string.sub(text, first, last)
			end
		end)

		if ok and #units > 0 then
			return units
		end

		for i = 1, #text do
			units[#units + 1] = string.sub(text, i, i)
		end
		return units
	end

	local function revealText(text)
		text = tostring(text or "")
		label.Text = ""
		label.TextTransparency = 1
		label.TextStrokeTransparency = 1
		label.Font = Enum.Font.Code
		label.Rotation = 0

		local revealTween = TweenService:Create(label, TweenInfo.new(0.65, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
			TextTransparency = 0.02,
			TextStrokeTransparency = 0.22,
		})
		revealTween:Play()

		local units = splitTextUnits(text)
		local currentText = ""
		local revealDuration = math.clamp(#units * 0.055, 0.9, 3.2)
		for i = 1, #units do
			if not gui.Parent then
				return
			end

			currentText = currentText .. units[i]
			label.Text = currentText
			task.wait(revealDuration / math.max(#units, 1))
		end

		label.Text = text
		task.wait(0.05)
	end

