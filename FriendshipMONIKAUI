local function muteOtherSounds()
	local fadingSounds = setmetatable({}, { __mode = "k" })

	local function fadeOutSound(inst)
		if not inst:IsA("Sound") or isProtectedSound(inst) or fadingSounds[inst] then
			return
		end

		fadingSounds[inst] = true

		task.spawn(function()
			local startVolume = inst.Volume
			local startSpeed = inst.PlaybackSpeed
			local steps = 35

			for step = 1, steps do
				if not inst.Parent or isProtectedSound(inst) then
					fadingSounds[inst] = nil
					return
				end

				local alpha = step / steps
				inst.Volume = math.max(0, startVolume * (1 - alpha))
				inst.PlaybackSpeed = math.clamp(startSpeed * (1 - alpha * 0.55), 0.25, 2)
				task.wait(0.1)
			end

			if inst.Parent and not isProtectedSound(inst) then
				inst.Volume = 0
				inst.PlaybackSpeed = math.clamp(startSpeed * 0.35, 0.25, 2)
			end

			fadingSounds[inst] = nil
		end)
	end

	local function muteIfSound(inst)
		if inst:IsA("Sound") and not isProtectedSound(inst) then
			fadeOutSound(inst)

			inst:GetPropertyChangedSignal("Volume"):Connect(function()
				if not isProtectedSound(inst) and inst.Volume ~= 0 then
					fadeOutSound(inst)
				end
			end)

			inst:GetPropertyChangedSignal("PlaybackSpeed"):Connect(function()
				if not isProtectedSound(inst) and inst.Volume ~= 0 then
					fadeOutSound(inst)
				end
			end)
		end
	end

	for _, inst in ipairs(game:GetDescendants()) do
		muteIfSound(inst)
	end

	game.DescendantAdded:Connect(muteIfSound)
end

