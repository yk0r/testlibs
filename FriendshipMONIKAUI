            for obj, kind in pairs(tracked) do
                local saved = base[obj]
                if not saved or not obj.Parent or not obj:IsDescendantOf(screenGui) then
                    tracked[obj] = nil
                    base[obj] = nil
                else
                    pcall(function()
                        if kind == "text" then
                            if obj:IsA("TextBox") and obj:IsFocused() then
                                obj.Font = saved.Font
                                obj.TextColor3 = saved.TextColor3
                                obj.TextStrokeColor3 = saved.TextStrokeColor3
                                obj.TextStrokeTransparency = saved.TextStrokeTransparency
                                return
                            end
                            obj.Font = HorrorFlickerFonts[HorrorRng:NextInteger(1, #HorrorFlickerFonts)]
                            obj.TextColor3 = pulse and Theme.Text or Theme.Accent
                            obj.TextStrokeColor3 = Theme.AccentDim
                            obj.TextStrokeTransparency = pulse and 0.78 or 0.9
                        end
                    end)
                end
            end

            task.wait(HorrorRng:NextNumber(0.055, 0.095))
        end

        if addedConn then
            addedConn:Disconnect()
        end
    end)
end

