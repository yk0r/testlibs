		end

		local yesButton = makeButton("Yes", "Yes", UDim2.fromScale(0.26, 0.5))
		local noButton = makeButton("No", "No", UDim2.fromScale(0.74, 0.5))

		local function choose(value)
			if finished then
				return
			end

			choice = value
			_G.HorrorYesNoChoice = value
			finished = true
		end

		connections[#connections + 1] = yesButton.Activated:Connect(function()
			choose("Yes")
		end)

		connections[#connections + 1] = noButton.Activated:Connect(function()
			choose("No")
		end)

		while gui.Parent and not finished do
			task.wait(0.05)
		end

		for _, connection in ipairs(connections) do
			connection:Disconnect()
		end

		if promptFrame.Parent then
			promptFrame:Destroy()
		end

		return choice
	end
	task.wait(25)

	local realNamePromptTextIndex = 9
	local yesNoPromptTextIndex = 21
	local realNamePromptTimeout = 20
	local realNameTimeoutText = "看来你还不想告诉我你的真名呢……不过没关系哦～你能留下来陪着我，我就已经心满意足了。\nIt looks like you still don’t want to tell me your real name… But that’s okay~ Just having you here with me is already enough to make me happy."
	local realNameSkipStartIndex = 10
	local realNameResumeTextIndex = 12
	storedRealNameInput = _G.HorrorRealNameInput
	sequenceRealNameInput = storedRealNameInput
	local skippedTextIndexes = {}

	for index, text in ipairs(texts) do
		if not gui.Parent then
			return
		end

		if skippedTextIndexes[index] then
			continue
		end

		revealText(resolveStoredText(text))
		local skipDefaultPause = false
		if index == realNamePromptTextIndex then
			local confirmed, enteredName = promptForRealName(realNamePromptTimeout)
			if not gui.Parent then
				return
			end

			if confirmed then
				sequenceRealNameInput = enteredName
			else
				task.wait(0.4)
				label.TextTransparency = 1
				label.TextStrokeTransparency = 1
				label.Text = ""
				revealText(realNameTimeoutText)
				task.wait(3)
				if not gui.Parent then
					return
				end
				label.TextTransparency = 1
				label.TextStrokeTransparency = 1
				label.Text = ""
				for skippedIndex = realNameSkipStartIndex, realNameResumeTextIndex - 1 do
					skippedTextIndexes[skippedIndex] = true
				end
				skipDefaultPause = true
			end
		end
		if index == yesNoPromptTextIndex then
			stopUiMutation()
			local choice = promptYesNoChoice()
			if not gui.Parent then
				return
			end
			if choice == "Yes" then
				triggerYesEnding()
				return
			elseif choice == "No" then
				if gui.Parent then
					gui:Destroy()
				end
				triggerNoEnding()
				return
			end
		end


		if not skipDefaultPause and index < #texts then
			task.wait(5)
			if not gui.Parent then
				return
			end
			label.TextTransparency = 1
			label.TextStrokeTransparency = 1
			label.Text = ""
		elseif not skipDefaultPause then
			task.wait(3)
		end
	end

	flicker = false
	local fadeTween = TweenService:Create(label, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.In), {
		TextTransparency = 1,
		TextStrokeTransparency = 1,
	})
	fadeTween:Play()
	fadeTween.Completed:Wait()

	if gui.Parent then
		gui:Destroy()
	end
end

local function lockPlayerFirstPerson()
	local applying = false
	local rightMouseDown = false

	local function applyFirstPerson()
		if firstPersonLockSuspended then
			return
		end

		if applying then
			return
		end

		applying = true
		pcall(function()
			player.CameraMode = Enum.CameraMode.LockFirstPerson
			player.CameraMinZoomDistance = 0.5
			player.CameraMaxZoomDistance = 0.5
			if not rightMouseDown then
				UserInputService.MouseBehavior = Enum.MouseBehavior.Default
			end
			UserInputService.MouseIconEnabled = true
		end)
		applying = false
	end

	applyFirstPerson()

	UserInputService.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton2 then
			rightMouseDown = true
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton2 then
			rightMouseDown = false
			task.defer(applyFirstPerson)
		end
	end)

	player:GetPropertyChangedSignal("CameraMode"):Connect(applyFirstPerson)
	player:GetPropertyChangedSignal("CameraMinZoomDistance"):Connect(applyFirstPerson)
	player:GetPropertyChangedSignal("CameraMaxZoomDistance"):Connect(applyFirstPerson)
	UserInputService:GetPropertyChangedSignal("MouseBehavior"):Connect(function()
		if not rightMouseDown then
			applyFirstPerson()
		end
	end)
	UserInputService:GetPropertyChangedSignal("MouseIconEnabled"):Connect(applyFirstPerson)

	task.spawn(function()
		while true do
			applyFirstPerson()
			task.wait(1.25)
		end
	end)
end

